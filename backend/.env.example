# Copy to backend/.env and fill in. .env is gitignored -- never commit real secrets.
# Anything unset just falls back to stub/JSON behavior; set only what you need.

# --- OpenRouter (one key runs the WHOLE stack). Per-seat model slugs:
#     translator = OPENROUTER_MODEL (gemini), agent + MCP brain = OPENROUTER_AGENT_MODEL (claude).
#     Run: --translators openrouter --agent-model openrouter --with-mcp ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3.5-flash        # translator seat
OPENROUTER_AGENT_MODEL=anthropic/claude-haiku-4.5  # agent seat + MCP brain
# OPENROUTER_MCP_MODEL=google/gemini-3.5-flash   # OPTIONAL: drive MCP with a different brain

# --- Freesolo-trained model (Layer 1) — the real trained AgentView translator ---
FREESOLO_API_KEY=            # the org fslo_ key
# Deployed <run-id>. Defaults to 4B-v4 (flash-1784420990-1f1e3398): 55% strict on
# the Mind2Web sample vs Gemini 35%. Swap to 9B-v4 (flash-1784420928-c6ce6a72) to
# compare. The run must be deployed (`flash deploy <run-id>`) and serving.
FREESOLO_MODEL=flash-1784420990-1f1e3398
# Serving endpoint. Defaults to the deployed modal URL; override only after a
# redeploy that lands on a different host (`flash deployments --json`).
FREESOLO_BASE_URL=https://clado-ai--freesolo-lora-serving.modal.run/v1

# --- MongoDB run logging (MLH track). Atlas "Connect -> Drivers" string, password filled in ---
MONGODB_URI=
MONGODB_DB=agentview
